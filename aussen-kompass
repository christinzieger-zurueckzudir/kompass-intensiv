<style>
:root{--bg:#fbf5ed;--card:#fffaf4;--text:#3f352b;--muted:#8a765f;--line:#eadcc8;--accent:#c99b63;--accent2:#8f9c76}*{box-sizing:border-box}body{margin:0;font-family:Georgia,"Times New Roman",serif;background:linear-gradient(180deg,var(--bg),#fffdf9);color:var(--text);line-height:1.64}.wrap{max-width:980px;margin:0 auto;padding:28px 18px 70px}.card{background:rgba(255,250,244,.96);border:1px solid var(--line);border-radius:28px;padding:34px;box-shadow:0 18px 50px rgba(80,58,34,.10);margin:20px 0}.hero{text-align:center;padding:54px 34px}.eyebrow{text-transform:uppercase;letter-spacing:.18em;color:var(--accent);font-size:.82rem;margin-bottom:8px}h1{font-size:2.45rem;line-height:1.12;margin:8px 0 12px}h2{font-size:1.55rem;margin:0 0 16px}h3{font-size:1.18rem;margin:24px 0 8px}h4{font-size:1.05rem;margin:18px 0 6px}p{margin:10px 0}.lead{font-size:1.08rem;color:var(--muted)}.hidden{display:none}.btn{border:0;background:var(--accent);color:white;padding:13px 22px;border-radius:999px;font-family:inherit;font-size:1rem;cursor:pointer;margin:8px 8px 0 0;box-shadow:0 8px 22px rgba(201,155,99,.25)}.btn.secondary{background:white;color:var(--text);border:1px solid var(--line);box-shadow:none}.note{background:#f5eadb;border-left:4px solid var(--accent);padding:14px 16px;border-radius:16px;margin:16px 0}.pill{display:inline-block;background:#f1e4d2;color:#6e573d;padding:6px 12px;border-radius:999px;margin:4px;font-size:.9rem}.grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.field label{display:block;color:var(--muted);font-size:.92rem;margin-bottom:6px}select,input,textarea{width:100%;padding:12px;border:1px solid var(--line);border-radius:15px;background:white;color:var(--text);font-family:inherit;font-size:1rem}textarea{min-height:82px}.progress{height:10px;background:#efe2d0;border-radius:999px;overflow:hidden;margin:14px 0 8px}.bar{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));width:0%;transition:.25s}.meta{text-align:right;color:var(--muted);font-size:.92rem}.question-title{font-size:1.34rem;margin:18px 0}.answers{display:grid;gap:12px}.answer{display:block;background:white;border:1px solid var(--line);border-radius:18px;padding:15px 16px;cursor:pointer}.answer:hover,.answer.selected{background:#fff4e4;border-color:var(--accent)}.answer input{width:auto;margin-right:10px}.result-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.result-box{background:white;border:1px solid var(--line);border-radius:20px;padding:18px;margin:12px 0}.score-row{margin:12px 0}.score-head{display:flex;justify-content:space-between;gap:12px;font-size:.95rem}.score-line{height:10px;background:#efe2d0;border-radius:999px;overflow:hidden;margin-top:6px}.score-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2))}.section-title{border-top:1px solid var(--line);padding-top:22px;margin-top:26px}.print-footer{margin-top:30px;padding:22px;background:#f5eadb;border-radius:18px;border-left:4px solid var(--accent)}ul{padding-left:22px}li{margin:6px 0}@media print{.btn,.progress,.meta{display:none}body{background:white}.card{box-shadow:none;border:0;padding:10px}.wrap{max-width:900px;padding:0}.print-footer,.result-box{page-break-inside:avoid}a{display:none}}@media(max-width:720px){.grid,.result-grid{grid-template-columns:1fr}.hero,.card{padding:24px}h1{font-size:2rem}}
